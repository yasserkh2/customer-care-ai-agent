# Secrets only.
# Put non-secret runtime settings (providers, models, qdrant paths, ingestion paths)
# in config.yml / config.yml.example.

# Gemini / Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional provider path in this project)
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Cohere (reranker)
COHERE_API_KEY=your_cohere_api_key_here

# Optional secret for hosted Qdrant
QDRANT_API_KEY=
