# Provider selection
EMBEDDING_PROVIDER=gemini

# Shared embedding fallback
EMBEDDING_MODEL=

# Gemini / Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
# Latest stable Gemini embedding model per Google docs (updated June 2025)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_OUTPUT_DIMENSION=1536
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=1.0

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# KB answer generation
KB_ANSWER_PROVIDER=gemini
# Or: KB_ANSWER_PROVIDER=openai
GEMINI_CHAT_MODEL=gemini-2.5-flash
# KB_ANSWER_SYSTEM_PROMPT=

# Local test provider
# EMBEDDING_PROVIDER=local

# Qdrant
QDRANT_COLLECTION=customer_care_kb
QDRANT_EMBEDDING_DIMENSION=1536
QDRANT_DISTANCE=cosine
QDRANT_PATH=vector_db/qdrant/data/local
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# Ingestion
FAQS_JSONL_PATH=cob_mock_kb_large/high_quality_faqs/high_quality_faqs.jsonl
FAQ_PIPELINE_BATCH_SIZE=3
